  \setcounter{mixsrc}{0}%
}
\newcommand{\addtobank}[2]{%
  \stepcounter{mixsrc}%
  \expandafter\xdef\csname mixsrc@\themixsrc @file\endcsname{#1}%
  \CatchFileDef{\bank}{#1}{}%
  \setcounter{totalquestions}{0}%
  \RenewEnviron{ex}{\stepcounter{totalquestions}}%
  \bank%
  \declarenumlist{mixsrclist\themixsrc}{1}{\thetotalquestions}%
  \foreach \uMixQ in {1,...,#2} {%
    \stepcounter{mixcount}%
    \pgfmathrandomitem\mixrandomq{mixsrclist\themixsrc}%
    \xdef\mixrandomq{\mixrandomq}%
    \prunelist{mixsrclist\themixsrc}%
    \expandafter\xdef\csname mixitem@\themixcount @src\endcsname{\themixsrc}%
    \expandafter\xdef\csname mixitem@\themixcount @q\endcsname{\mixrandomq}%
  }%
}
\newcommand{\domixbank}{%
  \ifnum\value{mixcount}>0\relax
  \setcounter{exrd}{0}%
  \edef\totalmix{\themixcount}%
  \declarenumlist{mixorder}{1}{\totalmix}%
  \foreach \uMixOut in {1,...,\totalmix} {%
    \pgfmathrandomitem\mixorderidx{mixorder}%
    \xdef\mixorderidx{\mixorderidx}%
    \prunelist{mixorder}%
    \edef\mixcursrc{\csname mixitem@\mixorderidx @src\endcsname}%
    \edef\mixcurq{\csname mixitem@\mixorderidx @q\endcsname}%
    \edef\mixcurfile{\csname mixsrc@\mixcursrc @file\endcsname}%
    \expandafter\CatchFileDef\expandafter\bank\expandafter{\mixcurfile}{}%
    \setcounter{ex}{0}%
    \RenewEnviron{ex}{%
      \stepcounter{ex}%
      \ifnum\value{ex}=\mixcurq\relax
        \par\begin{exrd}\BODY\end{exrd}%
      \fi
    }%
    \bank%
  }%
  \resetmixbank%
  \fi
}
