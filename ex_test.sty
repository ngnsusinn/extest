%Grid item renderers (tabular) - dùng etoolbox balanced conditionals
\makeatletter
\newcommand{\displayDSpattern}[1]{%
  \@displayDS#1\@nil
}
\def\@displayDS#1{%
  \ifx\@nil#1\else
    \if D#1\textbf{Đ}\else S\fi
    \expandafter\@displayDS
  \fi
}
%Helper: check if counter == colnum → end row
\newcommand{\gridcheckrow}[2]{%counter,colnum
  \ifnumequal{\value{#1}}{#2}{\\\hline\noalign{\setcounter{#1}{0}\gdef\gridMCsep{}\gdef\gridTFsep{}\gdef\gridSAsep{}}}{}%
}
%Recursive pad helper: fill remaining cells
\newcommand{\gridpadloop}[2]{%counter,max
  \ifnumless{\value{#1}}{#2}{\stepcounter{#1}&\gridpadloop{#1}{#2}}{}%
}
%MC: question number + answer in one cell, 12 columns
\newcommand{\gridMCitem}[2]{%
  \stepcounter{gridMCrow}%
  \gridMCsep
  \gdef\gridMCsep{&}%
  {\small #1}\newline\textbf{\color{blue}#2}%
  \gridcheckrow{gridMCrow}{\gridMCcolnum}%
}
%Pad remaining MC cells to fill row
\newcommand{\gridMCpadend}[1]{%
  \ifnumgreater{\value{gridMCrow}}{0}{\gridpadloop{gridMCrow}{#1}\\\hline}{}%
}
%TF: "Câu N   ĐSĐS" format, 4 columns
\newcommand{\gridTFitem}[2]{%
  \stepcounter{gridTFrow}%
  \gridTFsep
  \gdef\gridTFsep{&}%
  {\small Câu #1}\hfill\textbf{\color{blue}\displayDSpattern{#2}}%
  \gridcheckrow{gridTFrow}{\gridTFcolnum}%
}
\newcommand{\gridTFpadend}[1]{%
  \ifnumgreater{\value{gridTFrow}}{0}{\gridpadloop{gridTFrow}{#1}\\\hline}{}%
}
%SA: "Câu N   value" format, 6 columns
\newcommand{\gridSAitem}[2]{%
  \stepcounter{gridSArow}%
  \gridSAsep
  \gdef\gridSAsep{&}%
  {\small Câu #1}\hfill\textbf{\color{blue}#2}%
  \gridcheckrow{gridSArow}{\gridSAcolnum}%
}
\newcommand{\gridSApadend}[1]{%
  \ifnumgreater{\value{gridSArow}}{0}{\gridpadloop{gridSArow}{#1}\\\hline}{}%
}
\makeatother
