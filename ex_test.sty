  \ifstrequal{#1}{TF}{%
    \stepcounter{gridTFn}%
    \protected@xdef\gridTFlist{\gridTFlist\protect\gridTFitem{#2}{#3}}%
  }{}%
  \ifstrequal{#1}{SA}{%
    \stepcounter{gridSAn}%
    \protected@xdef\gridSAlist{\gridSAlist\protect\gridSAitem{#2}{#3}}%
  }{}%
}
\makeatother
